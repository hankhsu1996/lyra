# Test infrastructure for Lyra
#
# Suite-based test framework using YAML test specs in sv_features/
#
# Architecture:
#   cc_test (warm parent) -> forks one child per case -> isolated execution
#   Parent loads manifest once, child runs ExecuteTestCase in copy-on-write fork

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_library(
    name = "test_core",
    srcs = glob(["framework/*.cpp"]),
    hdrs = glob(["framework/*.hpp"]),
    deps = [
        "//:frontend",
        "//:llvm_backend",
        "//:lowering",
        "//:realization",
        "@slang",
        "@yaml-cpp",
    ],
)

# Shared data dependencies for suite tests.
_SUITE_DATA = [
    "suites.yaml",
    "//:liblyra_runtime.so",
    "//third_party/systemverilog:svdpi.h",
] + glob(["sv_features/**/*.yaml"]) + glob(["sv_features/**/*.c"])

cc_test(
    name = "jit_dev_tests",
    srcs = ["main.cpp"],
    args = ["--suite=jit_dev"],
    data = _SUITE_DATA,
    linkopts = ["-Wl,--export-dynamic"],  # Export symbols for ORC JIT
    shard_count = 4,
    deps = [":test_core"],
)

# JIT two-state suite - regression tests for --two-state mode
