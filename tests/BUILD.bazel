# Test infrastructure for Lyra
#
# Suite-based test framework using YAML test specs in sv_features/

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_library(
    name = "test_framework",
    srcs = glob(["framework/*.cpp"]),
    hdrs = glob(["framework/*.hpp"]),
    deps = [
        "//:frontend",
        "//:llvm_backend",
        "//:lowering",
        "//:realization",
        "@googletest//:gtest",
        "@slang",
        "@yaml-cpp",
    ],
)

# Test exclusion policy:
# JIT and AOT targets must not diverge through per-target gtest_filter rules.
# If a case is unsupported, express that in YAML expectations or skip metadata,
# not by target-local test filtering.

cc_test(
    name = "jit_dev_tests",
    srcs = ["main.cpp"],
    args = [
        "--suite=jit_dev",
    ],
    data = [
        "suites.yaml",
    ] + glob(["sv_features/**/*.yaml"]) + glob(["sv_features/**/*.c"]),
    shard_count = 4,
    deps = [
        ":test_framework",
        "@googletest//:gtest",
    ],
)

# JIT two-state suite - regression tests for --two-state mode
cc_test(
    name = "jit_two_state_tests",
    srcs = ["main.cpp"],
    args = ["--suite=jit_two_state"],
    data = [
        "suites.yaml",
    ] + glob(["sv_features/**/*.yaml"]) + glob(["sv_features/**/*.c"]),
    shard_count = 4,
    deps = [
        ":test_framework",
        "@googletest//:gtest",
    ],
)

# AOT development suite - full AOT pipeline (compile > link > execute)
cc_test(
    name = "aot_dev_tests",
    srcs = ["main.cpp"],
    args = ["--suite=aot_dev"],
    data = [
        "suites.yaml",
        "//:liblyra_runtime.so",
    ] + glob(["sv_features/**/*.yaml"]) + glob(["sv_features/**/*.c"]),
    shard_count = 4,
    deps = [
        ":test_framework",
        "@googletest//:gtest",
    ],
)

