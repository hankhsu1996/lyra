load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

cc_library(
    name = "framework",
    srcs = glob(["framework/*.cpp"]),
    hdrs = glob(["framework/*.hpp"]),
    visibility = ["//tests:__subpackages__"],
    deps = [
        "@fmt",
        "@yaml-cpp//:yaml-cpp",
    ],
)

cc_test(
    name = "cli_golden_tests",
    srcs = ["cli_golden_test.cpp"],
    data = [
        "suites.yaml",
        "//:lyra",
    ] + glob(
        [
            "cases/**/*.yaml",
            "cases/**/*.sv",
        ],
        allow_empty = True,
    ),
    deps = [
        ":framework",
        "@bazel_tools//tools/cpp/runfiles",
        "@fmt",
        "@googletest//:gtest",
    ],
)

cc_test(
    name = "diag_render_tests",
    srcs = ["diag/render_test.cpp"],
    deps = [
        "//:diag",
        "@googletest//:gtest_main",
    ],
)

cc_test(
    name = "cli_run_tests",
    srcs = ["cli_run_test.cpp"],
    data = [
        "//:lyra",
        "//:runtime_headers",
        "//:runtime_sources",
    ] + glob(
        ["cases/run/*.sv"],
        allow_empty = True,
    ),
    # Compiles emitted artifacts with the host C++ compiler. Skipped from
    # `bazel test //...` until a host C++ toolchain is wired into CI; mirrors
    # the disabled aot-full job in .github/workflows/bazel-build.yml. Run
    # locally with `bazel test //tests:cli_run_tests`.
    tags = ["manual"],
    deps = [
        ":framework",
        "@bazel_tools//tools/cpp/runfiles",
        "@googletest//:gtest_main",
    ],
)
